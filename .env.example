# Copy this file to .env and fill in the values for local development.
# .env is gitignored — never commit real credentials.
#
# In CI (GitHub Actions), these are set as repository secrets and injected
# into the build step automatically. See .github/workflows/deploy.yml.

# GitHub Pages project URL settings — only needed when building for a regular
# project page URL (e.g. username.github.io/promptrecovery.co.uk). Leave both
# unset for a custom domain or for local development and Playwright tests.
NEXT_PUBLIC_SITE_ORIGIN=https://your-username.github.io
NEXT_PUBLIC_BASE_PATH=/promptrecovery.co.uk

# Web3Forms access key — from https://web3forms.com/
# This is a public identifier, not a secret, but is kept here for consistency.
FORM_ACCESS_KEY=your-web3forms-access-key

# Google Tag Manager container ID — from https://tagmanager.google.com/
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Google Analytics measurement ID — from https://analytics.google.com/
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# NOINDEX for development/integration environments; exclude in production
APP_INDEX_MODE=NOINDEX

# Trello API access for syncing improvement-ideas/*.md cards to a board
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_TOKEN=your-trello-api-token
TRELLO_BOARD_ID=your-trello-board-id
