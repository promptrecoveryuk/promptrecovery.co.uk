{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    // "bundler" resolution mirrors how Next.js (via webpack/Turbopack) actually
    // resolves modules — it supports package.json `exports` fields and doesn't
    // require explicit file extensions in imports.
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    // Each file is treated as an isolated module, which is required for tools
    // like Babel/SWC that transpile one file at a time.
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    // The Next.js TypeScript plugin provides editor type-checking for things
    // like route params, metadata, and server/client component boundaries.
    "plugins": [{ "name": "next" }],
    // The `@/*` alias maps to `src/*`, matching the `paths` in next.config.ts.
    // Use it in imports: `import Foo from '@/components/Foo'`
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    // Types generated by Next.js for dynamic routes and other inference.
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
