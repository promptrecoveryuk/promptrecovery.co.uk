{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "browser-preview.startUrl": "http://local.promptrecovery.co.uk:3000",
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "tailwindCSS.classAttributes": ["class", "className", "theme"],
  "tailwindCSS.experimental.classRegex": [
    ["twMerge\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["createTheme(?:<\\w+>)?\\s*\\(([^)]*)\\)", "{?\\s?[\\w].*:\\s*?[\"'`]([^\"'`]*).*?,?\\s?}?"]
  ],
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#132f59",
    "activityBar.background": "#132f59",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#b82761",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#132f59",
    "statusBar.background": "#0a192f",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#132f59",
    "statusBarItem.remoteBackground": "#0a192f",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#0a192f",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#0a192f99",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#0a192f"
}
