{
  "name": "promptrecovery",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "copy-diff": "node --import tsx scripts/copy-diff.ts",
    "copy-diff:baseline": "node --import tsx scripts/copy-diff.ts capture --snapshot-set baseline",
    "copy-diff:baseline:live": "node --import tsx scripts/copy-diff.ts capture --snapshot-set baseline --base-url https://promptrecovery.co.uk",
    "copy-diff:current": "node --import tsx scripts/copy-diff.ts capture --snapshot-set current",
    "copy-diff:compare": "node --import tsx scripts/copy-diff.ts compare",
    "dev": "next dev",
    "dev:copy-diff": "COPY_DIFF=1 next dev",
    "build": "next build",
    "fetch-reviews": "node scripts/fetch-google-reviews.mjs",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "start": "next start",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "trello:sync": "node --import tsx scripts/trello-sync.ts",
    "test:ui": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@next/third-parties": "^15.3.2",
    "dotenv": "^16.4.7",
    "flowbite": "^4.0.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "^15.0.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "serve": "^14.2.6",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,scss,yml,yaml}": "prettier --write"
  }
}
